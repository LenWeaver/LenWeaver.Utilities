<Window x:Class="LenWeaver.Utilities.FontSelectionWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:LenWeaver.Utilities"
        mc:Ignorable="d"
        
        Background="{x:Static SystemColors.WindowBrush}"
        Title="Font Selection..."
        Height="450px" Width="800px"
        Icon="/LenWeaver.Utilities;component/Images/Symbol-Font-01.png"
        ResizeMode="NoResize"
        ShowInTaskbar="false"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <sys:Double         x:Key="BorderPanelWidth">250</sys:Double>
        
        <sys:String         x:Key="SampleTextLineOne">The quick brown fox jumps over the lazy dog.</sys:String>
        <sys:String         x:Key="SampleTextLineTwo">Lorem ipsum dolor sit amet, consectetur adipisicing elit.</sys:String>
        <sys:String         x:Key="SampleTextLineThree">The strongest enemy the Borg ever faced was species 8472, from fluidic space.</sys:String>
        <sys:String         x:Key="SampleTextLineFour">We shall go on to the end, we shall fight in France, we shall fight on the seas and oceans, we shall fight with growing confidence and growing strength in the air!</sys:String>
        <sys:String         x:Key="SampleTextLineFive">No!  Do, or do not.  There is no try.</sys:String>
        <sys:String         x:Key="SampleTextLineSix">Death smiles at us all, but all a man can do is smile back.</sys:String>
        
        <SolidColorBrush    x:Key="BorderBrush" Color="Black" />
        
        <Thickness          x:Key="BorderThickness">1</Thickness>
    </Window.Resources>
    
    
    <Grid                                   x:Name="grdMainGrid">
                            
        <Grid.ColumnDefinitions>
            <ColumnDefinition               Width="Auto"    MinWidth="250px"    />
            <ColumnDefinition               Width="10px"    />
            <ColumnDefinition               Width="Auto"    MinWidth="250px"    />
            <ColumnDefinition               Width="10px"    />
            <ColumnDefinition               Width="*"       />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition                  Height="*"      />
            <RowDefinition                  Height="Auto"   />
        </Grid.RowDefinitions>
        
        <GroupBox                           x:Name="brdFontFamily"      Grid.Column="0"         Grid.Row="0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="{StaticResource BorderThickness}"
                                            Header="Font Family:"
                                            Margin="10 5 0 10"
                                            Padding="2 0"
                                            Width="{StaticResource BorderPanelWidth}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition          Height="Auto"   />
                    <RowDefinition          Height="Auto"   />
                    <RowDefinition          Height="*"      />
                    <RowDefinition          Height="Auto"   />
                    <RowDefinition          Height="Auto"   />
                </Grid.RowDefinitions>
                
                <TextBox                    x:Name="txtSearch"          Grid.Row="0"
                                            AutoWordSelection="True"
                                            Margin="0 1 0 0"
                                            TabIndex="0" />
                <TextBlock                  x:Name="tbSearch"           Grid.Row="1"
                                            Margin="0 0 0 6"
                                            Text="Search:"
                                            Visibility="{Binding ElementName=txtSearch, Path=Visibility}" />
                
                <ListBox                    x:Name="lstFontFamily"      Grid.Row="2"
                                            TabIndex="1" />
                
                <ComboBox                   x:Name="cboFontSizeLeft"    Grid.Row="3"
                                            Margin="0 6 0 0"
                                            SelectedValuePath="Value"
                                            TabIndex="2" />
                <TextBlock                  x:Name="tbFontSizeLeft"     Grid.Row="4"
                                            Text="Font Size:"           Visibility="{Binding ElementName=cboFontSizeLeft, Path=Visibility}" />
            </Grid>
        </GroupBox>
                                            
        <GroupBox                           x:Name="grpTypeface"        Grid.Column="2"         Grid.Row="0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="{StaticResource BorderThickness}"
                                            Header="Typeface:"
                                            Margin="0 5 0 10"
                                            Padding="2 0"
                                            Width="{StaticResource BorderPanelWidth}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition          Height="Auto"   />
                    <RowDefinition          Height="Auto"   />
                    <RowDefinition          Height="*"      />
                </Grid.RowDefinitions>
                
                <ComboBox                   x:Name="cboFontSizeCenter"  Grid.Row="0"
                                            IsEditable="true" TextBlock.TextAlignment="Right" 
                                            Margin="0 1 0 0"
                                            TabIndex="3" />
                <TextBlock                  x:Name="tbFontSizeCenter"   Grid.Row="1"
                                            Margin="0 0 0 6"            Text="Font Size:"
                                            Visibility="{Binding ElementName=cboFontSizeCenter, Path=Visibility}" />
                
                <ListView                   x:Name="lvwTypeface"        Grid.Row="2"
                                            Margin="0 0 0 2"
                                            TabIndex="4">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Stretch"            Width="Auto"            DisplayMemberBinding="{Binding Stretch}"    />
                            <GridViewColumn Header="Style"              Width="Auto"            DisplayMemberBinding="{Binding Style}"      />
                            <GridViewColumn Header="Weight"             Width="Auto"            DisplayMemberBinding="{Binding Weight}"     />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>
        
        <GroupBox                           x:Name="grpSampleText"      Grid.Column="4"         Grid.Row="0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="{StaticResource BorderThickness}"
                                            Header="Sample Text:"
                                            Margin="0 5 10 10">
            <StackPanel>
                <TextBlock                  x:Name="tbSample"
                                            TextWrapping="Wrap">
                    
                    <Run                    FontSize="11pt" Text="{StaticResource SampleTextLineOne}" />
                    <LineBreak />
                    <Run                    FontSize="13pt" Text="{StaticResource SampleTextLineTwo}" />
                    <LineBreak />
                    <Run                    FontSize="15pt" Text="{StaticResource SampleTextLineThree}" />
                    <LineBreak />
                    <Run                    FontSize="17pt" Text="{StaticResource SampleTextLineFour}" />
                    <LineBreak />
                    <Run                    FontSize="19pt" Text="{StaticResource SampleTextLineFive}" />
                    <LineBreak />
                    <Run                    FontSize="21pt" Text="{StaticResource SampleTextLineSix}" />
                    
                </TextBlock>
            </StackPanel>
        </GroupBox>
        
        <Border                             x:Name="brdButtonBar"       Grid.Column="0"         Grid.Row="1"    Grid.ColumnSpan="5"
                                            Background="LightGray"
                                            BorderBrush="{x:Static SystemColors.ActiveCaptionBrush}"
                                            BorderThickness="0 1 0 0"
                                            Height="38px">
            <StackPanel                     Orientation="Horizontal"
                                            HorizontalAlignment="Right">

                <Button                     x:Name="btnSelect"
                                            Content="_Select"
                                            Height="23px"
                                            IsDefault="True"
                                            IsEnabled="False"
                                            Margin="5px"
                                            Width="80px" />

                <Button                     x:Name="btnClose"
                                            Content="_Close"
                                            Height="23px"
                                            IsCancel="True"
                                            Margin="5 5 10 5"
                                            Width="80px" />
            </StackPanel>
        </Border>
    </Grid>
</Window>