<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LenWeaver.Utilities">

    <local:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />


    <Style TargetType="{x:Type local:PopupBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PopupBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition   Width="Auto" />
                            <ColumnDefinition   Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox    x:Name="PART_TextBox"           Grid.Column="0"
                                    Text="{TemplateBinding Text}"
                                    AcceptsReturn="false"
                                    Background="Transparent"
                                    IsReadOnly="True"
                                    Padding="2"
                                    VerticalContentAlignment="Center" />

                        <Button     x:Name="PART_ClearButton"       Grid.Column="1"
                                    Content="✕"
                                    Height="{Binding ActualHeight, ElementName=PART_TextBox}"
                                    Width="{TemplateBinding MinimumButtonWidth}"
                                    VerticalAlignment="Center">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource NullOrEmptyToVisibility}">
                                            <Binding Path="Text" RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="ShowClearButton" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </Button.Visibility>
                        </Button>

                        <Button     x:Name="PART_PopupButton"       Grid.Column="2"
                                    Content="..."
                                    Height="{Binding ActualHeight, ElementName=PART_TextBox}"
                                    Width="{TemplateBinding MinimumButtonWidth}"
                                    VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>