<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:local="clr-namespace:LenWeaver.Utilities">

    <local:BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
    <sys:String x:Key="Collapse">Collapse</sys:String>
    
    
    <Style TargetType="{x:Type local:NavigationBarItem}">
        <Style.Triggers>
            <Trigger Property="ImageSide" Value="LeftSide">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type local:NavigationBarItem}">
                            <Border                     x:Name="brdBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="8" />
                                    </Grid.ColumnDefinitions>

                                    <Label              x:Name="lblSelectedIndicator"       Grid.Column="0"
                                                        Background="{TemplateBinding SelectedIndicator}"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        Margin="0 1" />

                                    <local:SymbolView   x:Name="svSymbol"                   Grid.Column="2"
                                                        Character="{TemplateBinding SymbolCharacter}"
                                                        FontFamily="{TemplateBinding SymbolFontFamily}"
                                                        Foreground="{TemplateBinding SymbolForeground}"
                                                        ImageSource="{TemplateBinding SymbolImageSource}"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        Padding="{TemplateBinding SymbolPadding}"
                                                        PathFill="{TemplateBinding SymbolPathFill}"
                                                        PathMarkup="{TemplateBinding SymbolPathMarkup}"
                                                        PathStroke="{TemplateBinding SymbolPathStroke}"
                                                        PathStrokeThickness="{TemplateBinding SymbolPathStrokeThickness}"
                                                        Height="{TemplateBinding Height}"
                                                        Width="{TemplateBinding Height}" />

                                    <Label              x:Name="lblText"                    Grid.Column="4"
                                                        BorderThickness="0"
                                                        BorderBrush="Black"
                                                        Padding="0"
                                                        Content="{TemplateBinding Text}"
                                                        FontFamily="{TemplateBinding FontFamily}"
                                                        FontSize="{TemplateBinding FontSize}"
                                                        FontStretch="{TemplateBinding FontStretch}"
                                                        FontStyle="{TemplateBinding FontStyle}"
                                                        FontWeight="{TemplateBinding FontWeight}"
                                                        Foreground="{TemplateBinding Foreground}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        VerticalAlignment="Center"
                                                        VerticalContentAlignment="Stretch" />

                                    <Label              x:Name="lblExtraIndicator"          Grid.Column="6"
                                                        Background="{TemplateBinding ExtraIndicator}"
                                                        Margin="0 1" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="ImageSide" Value="RightSide">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type local:NavigationBarItem}">
                            <Border                     x:Name="brdBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1">
                                <Grid                   ShowGridLines="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="6" />
                                    </Grid.ColumnDefinitions>

                                    <Label              x:Name="lblExtraIndicator"          Grid.Column="0"
                                                        Background="{TemplateBinding ExtraIndicator}"
                                                        Margin="0 1" />

                                    <Label              x:Name="lblText"                    Grid.Column="2"
                                                        Content="{TemplateBinding Text}"
                                                        FontFamily="{TemplateBinding FontFamily}"
                                                        FontSize="{TemplateBinding FontSize}"
                                                        FontStretch="{TemplateBinding FontStretch}"
                                                        FontStyle="{TemplateBinding FontStyle}"
                                                        FontWeight="{TemplateBinding FontWeight}"
                                                        Foreground="{TemplateBinding Foreground}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Right"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        VerticalAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch" />
                                    
                                    <local:SymbolView   x:Name="svSymbol"                   Grid.Column="4"
                                                        Character="{TemplateBinding SymbolCharacter}"
                                                        FontFamily="{TemplateBinding SymbolFontFamily}"
                                                        Foreground="{TemplateBinding SymbolForeground}"
                                                        ImageSource="{TemplateBinding SymbolImageSource}"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        Padding="{TemplateBinding SymbolPadding}"
                                                        PathFill="{TemplateBinding SymbolPathFill}"
                                                        PathMarkup="{TemplateBinding SymbolPathMarkup}"
                                                        PathStroke="{TemplateBinding SymbolPathStroke}"
                                                        PathStrokeThickness="{TemplateBinding SymbolPathStrokeThickness}"
                                                        Height="{TemplateBinding Height}"
                                                        Width="{TemplateBinding Height}" />

                                    <Label              x:Name="lblSelectedIndicator"       Grid.Column="6"
                                                        Background="{TemplateBinding SelectedIndicator}"
                                                        IsEnabled="{TemplateBinding IsEnabled}"
                                                        Margin="0 1" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="SymbolPadding" Value="4" />
            </Trigger>
            <Trigger Property="IsPressed" Value="False">
                <Setter Property="SymbolPadding" Value="3" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=MouseOverBackground}" />
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource Self}, Path=MouseOverForeground}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="False">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="Transparent" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>