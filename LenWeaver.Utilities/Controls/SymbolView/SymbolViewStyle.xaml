<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LenWeaver.Utilities">

    
    <local:PathMarkupConverter x:Key="PathConverter" />
    
    <Style TargetType="{x:Type local:SymbolView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SymbolView}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Viewbox x:Name="vbCharacter" 
                                     HorizontalAlignment="Stretch" 
                                     VerticalAlignment="Stretch" 
                                     Visibility="Visible">
                                <TextBlock x:Name="tbCharacter" 
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontWeight="{TemplateBinding FontWeight}" 
                                           Text="{TemplateBinding Character}"
                                           HorizontalAlignment="Stretch" 
                                           VerticalAlignment="Stretch"
                                           Background="Transparent" 
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Viewbox>
                            <Viewbox x:Name="vbImage" 
                                     HorizontalAlignment="Stretch" 
                                     VerticalAlignment="Stretch"
                                     Visibility="Collapsed">
                                <Image x:Name="imgImage" 
                                       Source="{TemplateBinding ImageSource}" />
                            </Viewbox>
                            <Viewbox x:Name="vbPath" 
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed" 
                                     Stretch="Fill" 
                                     StretchDirection="Both"
                                     Width="{TemplateBinding Height}">
                                <Path x:Name="pPath" 
                                      Fill="{TemplateBinding PathFill}" 
                                      Stroke="{TemplateBinding PathStroke}"
                                      StrokeThickness="{TemplateBinding PathStrokeThickness}" 
                                      Margin="{TemplateBinding Margin}"
                                      Data="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                               Path=PathMarkup, Converter={StaticResource PathConverter}}"
                                      Stretch="Fill" />
                            </Viewbox>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>